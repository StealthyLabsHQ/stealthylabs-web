# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/stealthylabs?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=your-super-secret-access-jwt-key-change-in-production
JWT_REFRESH_TOKEN_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100