RewriteEngine On

# 1. To remove .html extension from URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# 2. To redirect .html to non-.html (canonicalization)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Security Headers
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking - only allow same origin framing
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection (defense-in-depth for older browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy - limit information leakage
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy - disable unused browser features
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Strict Transport Security (HSTS) - force HTTPS for 1 year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy (CSP)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https://cdn.discordapp.com https://media.discordapp.net https://upload.wikimedia.org https://i.scdn.co; connect-src 'self' wss://api.lanyard.rest https://api.lanyard.rest https://api.codetabs.com https://contact-form-api.code-39c.workers.dev; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://contact-form-api.code-39c.workers.dev"
</IfModule>

# 4. Cache Control for HTML pages (always revalidate)
<IfModule mod_headers.c>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# 5. Browser Caching for assets (versioned via ?v=hash)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/json "access plus 1 week"
</IfModule>

# 6. GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
